<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip center" data-tip="Rank">Rk</th> <th aria-label="Player" data-stat="name_display" scope="col" class=" poptip sort_default_asc center">Player</th> <th aria-label="Age" data-stat="age" scope="col" class=" poptip center" data-tip="Player's age on January 31 of the season">Age</th> <th aria-label="Team" data-stat="team_name_abbr" scope="col" class=" poptip sort_default_asc center">Team</th> <th aria-label="Pos" data-stat="pos" scope="col" class=" poptip center" data-tip="Position">Pos</th> <th aria-label="G" data-stat="games" scope="col" class=" poptip center" data-tip="Games">G</th> <th aria-label="GS" data-stat="games_started" scope="col" class=" poptip center" data-tip="Games Started">GS</th> <th aria-label="MP" data-stat="mp" scope="col" class=" poptip sort_col center" data-tip="Minutes Played">MP</th> <th aria-label="PER" data-stat="per" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Player Efficiency Rating&lt;/b&gt;&lt;br&gt;A measure of per-minute production standardized such that the league average is 15." data-filter="1" data-name="">PER</th> <th aria-label="TS%" data-stat="ts_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;True Shooting Percentage&lt;/strong&gt;&lt;br&gt;A measure of shooting efficiency that takes into account 2-point field goals, 3-point field goals, and free throws." data-filter="1" data-name="">TS%</th> <th aria-label="3PAr" data-stat="fg3a_per_fga_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;3-Point Attempt Rate&lt;/strong&gt;&lt;br&gt;Percentage of FG Attempts from 3-Point Range" data-filter="1" data-name="">3PAr</th> <th aria-label="FTr" data-stat="fta_per_fga_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;Free Throw Attempt Rate&lt;/strong&gt;&lt;br&gt;Number of FT Attempts Per FG Attempt" data-filter="1" data-name="">FTr</th> <th aria-label="ORB%" data-stat="orb_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Offensive Rebound Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of available offensive rebounds a player grabbed while they were on the floor." data-filter="1" data-name="">ORB%</th> <th aria-label="DRB%" data-stat="drb_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Defensive Rebound Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of available defensive rebounds a player grabbed while they were on the floor." data-filter="1" data-name="">DRB%</th> <th aria-label="TRB%" data-stat="trb_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Total Rebound Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of available rebounds a player grabbed while they were on the floor." data-filter="1" data-name="">TRB%</th> <th aria-label="AST%" data-stat="ast_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Assist Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of teammate field goals a player assisted while they were on the floor." data-filter="1" data-name="">AST%</th> <th aria-label="STL%" data-stat="stl_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Steal Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of opponent possessions that end with a steal by the player while they were on the floor." data-filter="1" data-name="">STL%</th> <th aria-label="BLK%" data-stat="blk_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Block Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of opponent two-point field goal attempts blocked by the player while they were on the floor." data-filter="1" data-name="">BLK%</th> <th aria-label="TOV%" data-stat="tov_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Turnover Percentage&lt;/b&gt;&lt;br&gt;An estimate of turnovers committed per 100 plays." data-filter="1" data-name="">TOV%</th> <th aria-label="USG%" data-stat="usg_pct" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Usage Percentage&lt;/b&gt;&lt;br&gt;An estimate of the percentage of team plays used by a player while they were on the floor." data-filter="1" data-name="">USG%</th> <th aria-label="OWS" data-stat="ows" scope="col" class=" poptip center" data-tip="&lt;b&gt;Offensive Win Shares&lt;/b&gt;&lt;br&gt;An estimate of the number of wins contributed by a player due to offense." data-filter="1" data-name="">OWS</th> <th aria-label="DWS" data-stat="dws" scope="col" class=" poptip center" data-tip="&lt;b&gt;Defensive Win Shares&lt;/b&gt;&lt;br&gt;An estimate of the number of wins contributed by a player due to defense." data-filter="1" data-name="">DWS</th> <th aria-label="WS" data-stat="ws" scope="col" class=" poptip center" data-tip="&lt;b&gt;Win Shares&lt;/b&gt;&lt;br&gt;An estimate of the number of wins contributed by a player." data-filter="1" data-name="">WS</th> <th aria-label="WS/48" data-stat="ws_per_48" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Win Shares Per 48 Minutes&lt;/b&gt;&lt;br&gt;An estimate of the number of wins contributed by a player per 48 minutes (league average is approximately .100)" data-filter="1" data-name="">WS/48</th> <th aria-label="OBPM" data-stat="obpm" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Offensive Box Plus/Minus&lt;/b&gt;&lt;br&gt;A box score estimate of the offensive points per 100 possessions a player contributed above a league-average player, translated to an average team." data-filter="1" data-name="">OBPM</th> <th aria-label="DBPM" data-stat="dbpm" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Defensive Box Plus/Minus&lt;/b&gt;&lt;br&gt;A box score estimate of the defensive points per 100 possessions a player contributed above a league-average player, translated to an average team." data-filter="1" data-name="">DBPM</th> <th aria-label="BPM" data-stat="bpm" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Box Plus/Minus&lt;/b&gt;&lt;br&gt;A box score estimate of the points per 100 possessions a player contributed above a league-average player, translated to an average team." data-filter="1" data-name="">BPM</th> <th aria-label="VORP" data-stat="vorp" scope="col" class=" poptip center" data-tip="&lt;b&gt;Value over Replacement Player&lt;/b&gt;&lt;br&gt;A box score estimate of the points per 100 TEAM possessions that a player contributed above a replacement-level (-2.0) player, translated to an average team and prorated to an 82-game season.&lt;br&gt;&lt;br&gt;Multiply by 2.70 to convert to wins over replacement." data-filter="1" data-name="">VORP</th> <th aria-label="Awards" data-stat="awards" scope="col" class=" poptip sort_default_asc center">Awards</th> </tr> </thead> <tbody><tr data-row="0"> <th scope="row" class="right " data-stat="ranker" csk="1">1</th> <td class="left " data-append-csv="mccolcj01" data-stat="name_display" csk="McCollum CJ-1">CJ McCollum</td> <td class="right " data-stat="age">28</td> <td class="left " data-stat="team_name_abbr">POR</td> <td class="center " data-stat="pos">SG</td> <td class="right " data-stat="games">70</td> <td class="right " data-stat="games_started">70</td> <td class="right " data-stat="mp">2556</td> <td class="right " data-stat="per" csk="17.0271460000000000">17.0</td> <td class="right " data-stat="ts_pct" csk="0.5412550438">.541</td> <td class="right " data-stat="fg3a_per_fga_pct" csk="0.37